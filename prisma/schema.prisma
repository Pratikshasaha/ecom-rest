datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         Int     @id @default(autoincrement())
  name       String
  email      String  @unique
  vendorName String
  password   String
  mobile     String
  location   String
  role       String  @default("")
}

model Product {

  id             Int      @id @default(autoincrement())
  name           String
  quantity       Int
  price          Float
  details        String?
  imagePath      String?
  vendorLocation String
  category       String
  vendorId       Int?
  createdAt      DateTime @default(now())

  updatedAt      DateTime @updatedAt
}

